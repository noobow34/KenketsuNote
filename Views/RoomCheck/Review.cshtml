@using KenketsuNote.Data
@using KenketsuNote.Jobs
@{
    Layout = null;
    var result = (RoomCheckResult)ViewBag.Result;
    var gemini = ViewBag.Gemini as RoomInfoCheckJob.GeminiRoomCheckResponse;
    var room   = result?.Room;
    var token  = ViewBag.Token;
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>献血ルーム情報変更レビュー | けんけつノート</title>
    <style>
        body { font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", Meiryo, sans-serif; background: #fafafa; color: #333; margin: 0; padding: 16px; }
        .wrap { max-width: 800px; margin: 0 auto; }
        h1 { color: #b71c1c; font-size: 1.2rem; }
        .room-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
        .checked-at { font-size: 0.8rem; color: #999; margin-bottom: 16px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
        th, td { padding: 8px 10px; text-align: left; border: 1px solid #ddd; font-size: 0.9rem; }
        th { background: #f5f5f5; font-weight: 600; width: 130px; }
        td.col-check { width: 64px; text-align: center; }
        .val-db { color: #333; }
        .changed { background: #fff8e1; }
        .changes-box { background: #fff3e0; border-left: 4px solid #e65100; padding: 12px 16px; margin-bottom: 24px; border-radius: 4px; font-size: 0.9rem; }
        .changes-box ul { margin: 6px 0 0; padding-left: 18px; }
        .btn-row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .btn-approve { background: #d32f2f; color: white; border: none; padding: 12px 28px; border-radius: 8px; font-size: 1rem; cursor: pointer; font-weight: 600; }
        .btn-dismiss { background: #fff; color: #666; border: 1px solid #ccc; padding: 12px 28px; border-radius: 8px; font-size: 1rem; cursor: pointer; }
        .btn-approve:hover { background: #b71c1c; }
        .btn-dismiss:hover { background: #f5f5f5; }
        .official-link { font-size: 0.85rem; margin-bottom: 16px; }
        .official-link a { color: #1565c0; }
        input[type=checkbox] { width: 18px; height: 18px; cursor: pointer; accent-color: #d32f2f; }
        .col-check-header { width: 64px; text-align: center; font-size: 0.8rem; }
        /* 編集入力 */
        .edit-text { width: 100%; box-sizing: border-box; padding: 4px 6px; border: 1px solid #90caf9; border-radius: 4px; font-size: 0.9rem; background: #e3f2fd; color: #1565c0; font-weight: 600; }
        .edit-select { padding: 4px 6px; border: 1px solid #90caf9; border-radius: 4px; font-size: 0.9rem; background: #e3f2fd; color: #1565c0; font-weight: 600; }
        .time-pair { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
        .edit-time { padding: 3px 5px; border: 1px solid #90caf9; border-radius: 4px; font-size: 0.85rem; background: #e3f2fd; color: #1565c0; font-weight: 600; width: 100px; }
        .time-sep { color: #999; font-size: 0.85rem; }
        .col-gemini { min-width: 180px; }
        .edit-note { font-size: 0.75rem; color: #1565c0; margin-bottom: 6px; }
    </style>
</head>
<body>
<div class="wrap">
    <h1>⚠️ 献血ルーム情報の変更を確認してください</h1>
    <div class="room-name">@room?.RoomName</div>
    <div class="checked-at">チェック日時：@result?.CheckedAt.ToOffset(TimeSpan.FromHours(9)).ToString("yyyy/MM/dd HH:mm") JST</div>

    @if (room?.RoomUrl != null)
    {
        <div class="official-link">🔗 <a href="@room.RoomUrl" target="_blank" rel="noopener">公式サイトを確認する</a></div>
    }

    @if (result?.Changes != null)
    {
        <div class="changes-box">
            <strong>Geminiが検出した差分：</strong>
            <ul>
                @foreach (var c in result.Changes.Split(',', StringSplitOptions.TrimEntries))
                {
                    <li>@c</li>
                }
            </ul>
        </div>
    }

    <p class="edit-note">✏️ Gemini抽出値は反映前に編集できます。</p>

    <form method="post" action="/admin/room-check/@result?.Id/approve?token=@token">

        @{
            bool CityChanged     = gemini?.City        != null && gemini.City        != room?.City;
            bool WholeChanged    = gemini?.CanWhole    != null && gemini.CanWhole    != room?.CanWhole;
            bool PlasmaChanged   = gemini?.CanPlasma   != null && gemini.CanPlasma   != room?.CanPlasma;
            bool PlateletChanged = gemini?.CanPlatelet != null && gemini.CanPlatelet != room?.CanPlatelet;
            bool ClosedChanged   = gemini?.ClosedDays  != null && gemini.ClosedDays  != room?.ClosedDays;

            string Bool2Str(bool? v) => v == true ? "可" : v == false ? "不可" : "未設定";
        }

        <table>
            <thead>
                <tr>
                    <th>項目</th>
                    <th>現在のDB値</th>
                    <th class="col-gemini">Gemini抽出値（編集可）</th>
                    <th class="col-check-header">反映する</th>
                </tr>
            </thead>
            <tbody>
                <tr class="@(CityChanged ? "changed" : "")">
                    <th>市区町村</th>
                    <td class="val-db">@(room?.City ?? "未設定")</td>
                    <td><input type="text" name="City" value="@gemini?.City" class="edit-text" /></td>
                    <td class="col-check">@if (CityChanged) { <input type="checkbox" name="fields" value="city" checked /> }</td>
                </tr>
                <tr class="@(WholeChanged ? "changed" : "")">
                    <th>全血</th>
                    <td class="val-db">@Bool2Str(room?.CanWhole)</td>
                    <td>
                        <select name="CanWhole" class="edit-select">
                            <option value=""      selected="@(gemini?.CanWhole == null)">未設定</option>
                            <option value="True"  selected="@(gemini?.CanWhole == true)">可</option>
                            <option value="False" selected="@(gemini?.CanWhole == false)">不可</option>
                        </select>
                    </td>
                    <td class="col-check">@if (WholeChanged) { <input type="checkbox" name="fields" value="can_whole" checked /> }</td>
                </tr>
                <tr class="@(PlasmaChanged ? "changed" : "")">
                    <th>血漿成分</th>
                    <td class="val-db">@Bool2Str(room?.CanPlasma)</td>
                    <td>
                        <select name="CanPlasma" class="edit-select">
                            <option value=""      selected="@(gemini?.CanPlasma == null)">未設定</option>
                            <option value="True"  selected="@(gemini?.CanPlasma == true)">可</option>
                            <option value="False" selected="@(gemini?.CanPlasma == false)">不可</option>
                        </select>
                    </td>
                    <td class="col-check">@if (PlasmaChanged) { <input type="checkbox" name="fields" value="can_plasma" checked /> }</td>
                </tr>
                <tr class="@(PlateletChanged ? "changed" : "")">
                    <th>血小板成分</th>
                    <td class="val-db">@Bool2Str(room?.CanPlatelet)</td>
                    <td>
                        <select name="CanPlatelet" class="edit-select">
                            <option value=""      selected="@(gemini?.CanPlatelet == null)">未設定</option>
                            <option value="True"  selected="@(gemini?.CanPlatelet == true)">可</option>
                            <option value="False" selected="@(gemini?.CanPlatelet == false)">不可</option>
                        </select>
                    </td>
                    <td class="col-check">@if (PlateletChanged) { <input type="checkbox" name="fields" value="can_platelet" checked /> }</td>
                </tr>
                <tr class="@(ClosedChanged ? "changed" : "")">
                    <th>定休日</th>
                    <td class="val-db">@(room?.ClosedDays ?? "なし")</td>
                    <td><input type="text" name="ClosedDays" value="@gemini?.ClosedDays" class="edit-text" /></td>
                    <td class="col-check">@if (ClosedChanged) { <input type="checkbox" name="fields" value="closed_days" checked /> }</td>
                </tr>
            </tbody>
        </table>

        @if (gemini?.BusinessHours is { Count: > 0 } || room?.BusinessHours.Count > 0)
        {
            <h2 style="font-size:1rem;color:#b71c1c;margin-bottom:8px;">営業時間</h2>
            <table>
                <thead>
                    <tr>
                        <th style="width:90px;">区分</th>
                        <th>現在のDB値</th>
                        <th class="col-gemini">Gemini抽出値（編集可）</th>
                        <th class="col-check-header">反映する</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        string DbTime(TimeOnly? s, TimeOnly? e) => s.HasValue ? $"{s:HH\\:mm}〜{e:HH\\:mm}" : "なし";
                    }
                    @foreach (var dayType in new[] { 0, 1 })
                    {
                        var label   = dayType == 0 ? "平日" : "土日祝";
                        var prefix0 = dayType == 0 ? "Bh0" : "Bh1";
                        var fieldName = $"business_hours_{dayType}";
                        var dbH = room?.BusinessHours.FirstOrDefault(h => h.DayType == dayType);
                        var gmH = gemini?.BusinessHours?.FirstOrDefault(h => h.DayType == dayType);

                        var wholeChg      = dbH != null && gmH != null && $"{dbH.WholeReceptionStart:HH\\:mm}〜{dbH.WholeReceptionEnd:HH\\:mm}" != $"{gmH.WholeReceptionStart}〜{gmH.WholeReceptionEnd}";
                        var wholeLunchChg = dbH != null && gmH != null && $"{dbH.WholeLunchStart:HH\\:mm}〜{dbH.WholeLunchEnd:HH\\:mm}"         != $"{gmH.WholeLunchStart}〜{gmH.WholeLunchEnd}";
                        var compChg       = dbH != null && gmH != null && $"{dbH.CompReceptionStart:HH\\:mm}〜{dbH.CompReceptionEnd:HH\\:mm}"   != $"{gmH.CompReceptionStart}〜{gmH.CompReceptionEnd}";
                        var compLunchChg  = dbH != null && gmH != null && $"{dbH.CompLunchStart:HH\\:mm}〜{dbH.CompLunchEnd:HH\\:mm}"           != $"{gmH.CompLunchStart}〜{gmH.CompLunchEnd}";
                        var anyHoursChg   = wholeChg || wholeLunchChg || compChg || compLunchChg;

                        <tr class="@(wholeChg ? "changed" : "")">
                            <th>@label 全血受付</th>
                            <td class="val-db">@DbTime(dbH?.WholeReceptionStart, dbH?.WholeReceptionEnd)</td>
                            <td>
                                <div class="time-pair">
                                    <input type="time" name="@(prefix0)WholeStart" value="@gmH?.WholeReceptionStart" class="edit-time" />
                                    <span class="time-sep">〜</span>
                                    <input type="time" name="@(prefix0)WholeEnd" value="@gmH?.WholeReceptionEnd" class="edit-time" />
                                </div>
                            </td>
                            <td class="col-check" rowspan="4">@if (anyHoursChg) { <input type="checkbox" name="fields" value="@fieldName" checked /> }</td>
                        </tr>
                        <tr class="@(wholeLunchChg ? "changed" : "")">
                            <th>@label 全血昼中断</th>
                            <td class="val-db">@DbTime(dbH?.WholeLunchStart, dbH?.WholeLunchEnd)</td>
                            <td>
                                <div class="time-pair">
                                    <input type="time" name="@(prefix0)WholeLunchStart" value="@gmH?.WholeLunchStart" class="edit-time" />
                                    <span class="time-sep">〜</span>
                                    <input type="time" name="@(prefix0)WholeLunchEnd" value="@gmH?.WholeLunchEnd" class="edit-time" />
                                </div>
                            </td>
                        </tr>
                        <tr class="@(compChg ? "changed" : "")">
                            <th>@label 成分受付</th>
                            <td class="val-db">@DbTime(dbH?.CompReceptionStart, dbH?.CompReceptionEnd)</td>
                            <td>
                                <div class="time-pair">
                                    <input type="time" name="@(prefix0)CompStart" value="@gmH?.CompReceptionStart" class="edit-time" />
                                    <span class="time-sep">〜</span>
                                    <input type="time" name="@(prefix0)CompEnd" value="@gmH?.CompReceptionEnd" class="edit-time" />
                                </div>
                            </td>
                        </tr>
                        <tr class="@(compLunchChg ? "changed" : "")">
                            <th>@label 成分昼中断</th>
                            <td class="val-db">@DbTime(dbH?.CompLunchStart, dbH?.CompLunchEnd)</td>
                            <td>
                                <div class="time-pair">
                                    <input type="time" name="@(prefix0)CompLunchStart" value="@gmH?.CompLunchStart" class="edit-time" />
                                    <span class="time-sep">〜</span>
                                    <input type="time" name="@(prefix0)CompLunchEnd" value="@gmH?.CompLunchEnd" class="edit-time" />
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="btn-row">
            <button type="submit" class="btn-approve">✅ 選択した項目をDBに反映する</button>
            <form method="post" action="/admin/room-check/@result?.Id/dismiss?token=@token">
                <button type="submit" class="btn-dismiss">❌ 却下する（DBは変更しない）</button>
            </form>
        </div>

    </form>

    <p style="margin-top:20px;"><a href="/admin" style="color:#1565c0;font-size:0.9rem;">← 管理画面に戻る</a></p>
</div>
@await Html.PartialAsync("_VersionFooter")
</body>
</html>
