@using KenketsuNote.Data
@{
    Layout = null;
    var checkResults = ViewBag.CheckResults as List<RoomCheckResult> ?? new();
    var searchLogs   = ViewBag.SearchLogs   as List<RoomSearchLog>   ?? new();
    bool hideAdmin   = ViewBag.HideAdmin ?? true;
}
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>管理画面 | けんけつノート</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f5;color:#333;}
.wrap{max-width:900px;margin:0 auto;padding:24px 16px 60px;}
.topbar{background:#333;color:white;padding:14px 16px;margin-bottom:24px;display:flex;align-items:center;gap:16px;}
.topbar h1{font-size:1rem;font-weight:700;}
.topbar small{font-size:0.75rem;color:#aaa;margin-left:8px;}
.topbar-logout{margin-left:auto;font-size:0.8rem;color:#aaa;text-decoration:none;}
.topbar-logout:hover{color:white;}
.section{background:white;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.08);margin-bottom:16px;overflow:hidden;}
.section-header{padding:14px 16px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:8px;}
.section-icon{font-size:1.1rem;}
.section-title{font-size:0.95rem;font-weight:700;color:#333;}
.section-body{padding:14px 16px;}
.action-btn{display:flex;align-items:center;justify-content:space-between;width:auto;padding:10px 18px;border:1.5px solid #ddd;border-radius:8px;background:white;cursor:pointer;font-size:0.9rem;color:#333;text-align:left;margin-bottom:8px;transition:background 0.12s;}
.action-btn:hover{background:#f8f8f8;}
.btn-label{font-weight:600;}
.btn-desc{font-size:0.78rem;color:#888;margin-top:2px;}
.result-box{margin-top:10px;padding:10px 12px;border-radius:6px;font-size:0.85rem;display:none;}
.result-box.ok {background:#e8f5e9;color:#2e7d32;border:1px solid #a5d6a7;}
.result-box.err{background:#fce4ec;color:#b71c1c;border:1px solid #f48fb1;}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid #ccc;border-top-color:#555;border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:middle;margin-right:6px;}
@@keyframes spin{to{transform:rotate(360deg);}}
table{width:100%;border-collapse:collapse;font-size:0.85rem;}
th,td{padding:8px 10px;text-align:left;border-bottom:1px solid #f0f0f0;vertical-align:top;}
th{font-weight:600;color:#666;background:#fafafa;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:#fafcff;}
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;}
.badge-unresolved{background:#fff3e0;color:#e65100;border:1px solid #ffcc80;}
.badge-resolved{background:#e8f5e9;color:#2e7d32;border:1px solid #a5d6a7;}
.badge-changes{background:#fce4ec;color:#b71c1c;border:1px solid #f48fb1;}
.badge-nochange{background:#f5f5f5;color:#888;border:1px solid #ddd;}
.badge-admin{background:#e8eaf6;color:#3949ab;border:1px solid #9fa8da;}
a{color:#1565c0;}
.changes-text{font-size:0.8rem;color:#666;max-width:300px;}
.empty-msg{color:#aaa;font-size:0.9rem;padding:12px 0;}
.pagination{display:flex;align-items:center;gap:6px;margin-top:12px;font-size:0.85rem;}
.pagination a{padding:4px 10px;border:1px solid #ddd;border-radius:6px;color:#1565c0;text-decoration:none;}
.pagination a:hover{background:#e3f2fd;}
.pagination .current{padding:4px 10px;border:1px solid #1565c0;border-radius:6px;background:#1565c0;color:white;font-weight:600;}
.pagination .disabled{padding:4px 10px;color:#ccc;}
/* ── ルームピッカー ── */
.room-select-row{display:flex;align-items:center;gap:8px;margin-top:8px;}
.room-select-btn{display:flex;align-items:center;justify-content:space-between;flex:1;padding:8px 10px;border:1.5px solid #e0e0e0;border-radius:8px;background:white;font-size:0.88rem;cursor:pointer;color:#333;text-align:left;}
.room-select-btn:hover{border-color:#1565c0;}
.room-select-btn .room-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.room-select-btn .room-clear{flex-shrink:0;margin-left:6px;color:#bbb;font-size:0.75rem;}
.room-select-btn .room-clear:hover{color:#e74c3c;}
.run-single-btn{padding:8px 16px;border:none;border-radius:8px;background:#1565c0;color:white;font-size:0.88rem;font-weight:600;cursor:pointer;white-space:nowrap;}
.run-single-btn:hover{background:#0d47a1;}
/* ── モーダル ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1000;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-box{background:white;border-radius:14px;padding:20px;width:90%;max-width:480px;max-height:90vh;overflow-y:auto;position:relative;}
.modal-close{position:absolute;top:12px;right:14px;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#aaa;}
.modal-title{font-size:1rem;font-weight:700;margin-bottom:14px;color:#333;}
.room-picker-search{width:100%;padding:9px 12px;border:1.5px solid #e0e0e0;border-radius:8px;font-size:0.9rem;box-sizing:border-box;margin-bottom:10px;}
.room-picker-search:focus{outline:none;border-color:#1565c0;}
.pref-filter{display:flex;gap:6px;overflow-x:auto;padding-bottom:6px;margin-bottom:8px;scrollbar-width:thin;}
.pref-filter-btn{flex-shrink:0;padding:4px 10px;border:1.5px solid #ddd;border-radius:14px;background:white;font-size:0.75rem;cursor:pointer;white-space:nowrap;color:#555;}
.pref-filter-btn.active{border-color:#1565c0;background:#e3f2fd;color:#1565c0;font-weight:700;}
.room-list{height:280px;overflow-y:auto;border:1px solid #f0f0f0;border-radius:8px;}
.room-list-item{padding:9px 12px;font-size:0.85rem;cursor:pointer;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:8px;}
.room-list-item:last-child{border-bottom:none;}
.room-list-item:hover{background:#e3f2fd;}
.room-list-item.none-item{color:#aaa;font-style:italic;}
.room-list-item .room-pref-tag{font-size:0.72rem;color:#aaa;flex-shrink:0;}
.room-list-empty{padding:16px;text-align:center;color:#aaa;font-size:0.85rem;}
</style>
</head>
<body>

<div class="topbar">
    <h1>けんけつノート <small>管理画面</small></h1>
    <a class="topbar-logout" href="/u/noobow" style="margin-left:0;">マイページ</a>
    <a class="topbar-logout" href="/">トップ</a>
    <a class="topbar-logout" href="/account/logout">ログアウト</a>
</div>

<div class="wrap">

    <!-- ── マスタデータ ── -->
    <div class="section">
        <div class="section-header">
            <span class="section-icon">🗄️</span>
            <span class="section-title">マスタデータ</span>
        </div>
        <div class="section-body">
            <button class="action-btn" onclick="runAction('reload-master', this)">
                <div>
                    <div class="btn-label">マスタデータ再ロード</div>
                    <div class="btn-desc">献血ルーム・都道府県・ブロック情報をDBから再読み込み</div>
                </div>
            </button>
            <div class="result-box" id="result-reload-master"></div>
        </div>
    </div>

    <!-- ── Gemini差分チェック ── -->
    <div class="section">
        <div class="section-header">
            <span class="section-icon">🤖</span>
            <span class="section-title">Gemini差分チェック</span>
        </div>
        <div class="section-body">
            <div style="border-bottom:1px solid #f0f0f0;padding-bottom:12px;margin-bottom:12px;">
                <div class="btn-label" style="font-size:0.88rem;margin-bottom:6px;">自動実行時刻（JST）</div>
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <input type="number" id="schedHour"   min="0" max="23" value="@ViewBag.ScheduledHour"
                           style="width:60px;padding:7px;border:1.5px solid #ddd;border-radius:6px;font-size:0.95rem;text-align:center;">
                    <span style="font-size:1.1rem;font-weight:700;">:</span>
                    <input type="number" id="schedMinute" min="0" max="59" value="@ViewBag.ScheduledMinute"
                           style="width:60px;padding:7px;border:1.5px solid #ddd;border-radius:6px;font-size:0.95rem;text-align:center;">
                    <button class="run-single-btn" onclick="updateSchedule(this)">変更</button>
                </div>
                <div class="result-box" id="result-update-schedule"></div>
            </div>
            <button class="action-btn" onclick="runAction('run-room-check', this)">
                <div>
                    <div class="btn-label">バッチ実行</div>
                    <div class="btn-desc">次のバッチ（10ルーム）をGeminiでチェックします。完了まで数分かかります。</div>
                </div>
            </button>
            <div class="result-box" id="result-run-room-check"></div>
            <div style="margin-top:12px;border-top:1px solid #f0f0f0;padding-top:12px;">
                <div class="btn-label" style="font-size:0.88rem;margin-bottom:6px;">特定ルームを指定して実行</div>
                <div class="room-select-row">
                    <button type="button" class="room-select-btn" onclick="openRoomPicker()">
                        <span class="room-name" id="singleRoomName">ルームを選択…</span>
                        <span class="room-clear" onclick="clearSingleRoom();event.stopPropagation()">✕</span>
                    </button>
                    <input type="hidden" id="singleRoomId">
                    <button type="button" class="run-single-btn" onclick="runSingleCheck(this)">実行</button>
                </div>
                <div class="result-box" id="result-run-room-check-single"></div>
            </div>
        </div>
    </div>

    <!-- ── Gemini差分チェックログ ── -->
    <div class="section">
        <div class="section-header">
            <span class="section-icon">🤖</span>
            <span class="section-title">Gemini差分チェックログ（@ViewBag.CheckPage ページ目 / @ViewBag.CheckTotalPages ページ）</span>
        </div>
        <div class="section-body">
            @if (!checkResults.Any())
            {
                <p class="empty-msg">チェック結果はありません。</p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>チェック日時</th>
                            <th>献血ルーム</th>
                            <th>差分</th>
                            <th>状態</th>
                            <th>変更内容</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in checkResults)
                        {
                            <tr>
                                <td>@r.CheckedAt.ToOffset(TimeSpan.FromHours(9)).ToString("MM/dd HH:mm")</td>
                                <td>@(r.Room?.RoomName ?? $"ID:{r.RoomId}")</td>
                                <td>
                                    @if (r.HasChanges)
                                    {
                                        <span class="badge badge-changes">差分あり</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-nochange">変更なし</span>
                                    }
                                </td>
                                <td>
                                    @if (r.Resolved)
                                    {
                                        <span class="badge badge-resolved">対応済み</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-unresolved">未対応</span>
                                    }
                                </td>
                                <td class="changes-text">@r.Changes</td>
                                <td>
                                    @if (r.HasChanges && !r.Resolved)
                                    {
                                        <a href="/admin/room-check/@r.Id?token=@r.ReviewToken">レビュー</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="pagination">
                    @if (ViewBag.CheckPage > 1)
                    {
                        <a href="?checkPage=@(ViewBag.CheckPage - 1)&logPage=@ViewBag.LogPage&hideAdmin=@hideAdmin.ToString().ToLower()">前へ</a>
                    }
                    else
                    {
                        <span class="disabled">前へ</span>
                    }
                    <span class="current">@ViewBag.CheckPage</span>
                    <span>/ @ViewBag.CheckTotalPages</span>
                    @if (ViewBag.CheckPage < ViewBag.CheckTotalPages)
                    {
                        <a href="?checkPage=@(ViewBag.CheckPage + 1)&logPage=@ViewBag.LogPage&hideAdmin=@hideAdmin.ToString().ToLower()">次へ</a>
                    }
                    else
                    {
                        <span class="disabled">次へ</span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ── 検索ログ ── -->
    <div class="section">
        <div class="section-header">
            <span class="section-icon">🔍</span>
            <span class="section-title" id="logSectionTitle">検索ログ（@ViewBag.LogPage ページ目 / @ViewBag.LogTotalPages ページ）</span>
        </div>
        <div class="section-body">
            <div style="margin-bottom:10px;">
                <label style="font-size:0.85rem;display:flex;align-items:center;gap:6px;cursor:pointer;">
                    <input type="checkbox" id="hideAdminCheck" @(hideAdmin ? "checked" : "")
                           onchange="loadLogPage(1)">
                    管理者の検索を除外
                </label>
            </div>
            <div id="logTableArea">
                @await Html.PartialAsync("_SearchLogTable")
            </div>
        </div>
    </div>

</div>

<!-- ── ルームピッカーモーダル ── -->
<div class="modal-overlay" id="modalRoomPicker" onclick="if(event.target===this)closeRoomPicker()">
    <div class="modal-box">
        <button class="modal-close" onclick="closeRoomPicker()">×</button>
        <div class="modal-title">献血ルームを選択</div>
        <input type="text" class="room-picker-search" id="roomPickerSearch" placeholder="ルーム名で検索…" oninput="filterRooms()">
        <div class="pref-filter" id="prefFilter"></div>
        <div class="room-list" id="roomPickerList"></div>
    </div>
</div>

<script>
const ROOMS    = @Html.Raw(ViewBag.RoomsJson  ?? "[]");
const PREFS    = @Html.Raw(ViewBag.PrefsJson  ?? "[]");
const BLOCKS   = @Html.Raw(ViewBag.BlocksJson ?? "[]");
const PREF_MAP = Object.fromEntries(PREFS.map(p => [p.prefId, p.prefName]));

let _pickerPref = null;

function openRoomPicker() {
    _pickerPref = null;
    document.getElementById('roomPickerSearch').value = '';
    buildPrefFilter();
    filterRooms();
    document.getElementById('modalRoomPicker').classList.add('open');
    setTimeout(() => document.getElementById('roomPickerSearch').focus(), 80);
}
function closeRoomPicker() {
    document.getElementById('modalRoomPicker').classList.remove('open');
}
function buildPrefFilter() {
    const el = document.getElementById('prefFilter');
    el.innerHTML = '';
    const allBtn = document.createElement('button');
    allBtn.className = 'pref-filter-btn active';
    allBtn.textContent = 'すべて';
    allBtn.onclick = () => setPrefFilter(null, allBtn);
    el.appendChild(allBtn);
    BLOCKS.forEach(b => {
        PREFS.filter(p => p.centerBlockId === b.centerBlockId).forEach(p => {
            const btn = document.createElement('button');
            btn.className = 'pref-filter-btn';
            btn.textContent = p.prefName;
            btn.onclick = () => setPrefFilter(p.prefId, btn);
            el.appendChild(btn);
        });
    });
}
function setPrefFilter(prefId, btn) {
    _pickerPref = prefId;
    document.querySelectorAll('.pref-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filterRooms();
}
function filterRooms() {
    const q = document.getElementById('roomPickerSearch').value.trim().toLowerCase();
    const list = document.getElementById('roomPickerList');
    const filtered = ROOMS.filter(r => {
        if (_pickerPref && r.prefId !== _pickerPref) return false;
        if (q && r.roomName.toLowerCase().indexOf(q) === -1) return false;
        return true;
    });
    list.innerHTML = '';
    if (filtered.length === 0) {
        list.innerHTML = '<div class="room-list-empty">該当するルームがありません</div>';
        return;
    }
    filtered.forEach(r => {
        const item = document.createElement('div');
        item.className = 'room-list-item';
        const nameSpan = document.createElement('span');
        nameSpan.style.flex = '1';
        nameSpan.textContent = r.roomName;
        const prefSpan = document.createElement('span');
        prefSpan.className = 'room-pref-tag';
        prefSpan.textContent = PREF_MAP[r.prefId] || '';
        item.appendChild(nameSpan);
        item.appendChild(prefSpan);
        item.onclick = () => selectRoom(r.roomId, r.roomName);
        list.appendChild(item);
    });
}
function selectRoom(id, name) {
    closeRoomPicker();
    document.getElementById('singleRoomId').value = id;
    document.getElementById('singleRoomName').textContent = name;
}
function clearSingleRoom() {
    document.getElementById('singleRoomId').value = '';
    document.getElementById('singleRoomName').textContent = 'ルームを選択…';
}

async function runSingleCheck(btn) {
    const roomId = document.getElementById('singleRoomId').value;
    if (!roomId) { alert('ルームを選択してください。'); return; }
    const resultEl = document.getElementById('result-run-room-check-single');
    resultEl.className = 'result-box';
    resultEl.style.display = 'block';
    resultEl.innerHTML = '<span class="spinner"></span>実行中…';
    btn.disabled = true;
    try {
        const fd = new FormData();
        fd.append('roomId', roomId);
        const res  = await fetch('/admin/run-room-check-single', { method: 'POST', body: fd });
        const data = await res.json();
        resultEl.className = 'result-box ' + (data.success ? 'ok' : 'err');
        resultEl.textContent = data.message;
    } catch (e) {
        resultEl.className = 'result-box err';
        resultEl.textContent = '通信エラー: ' + e.message;
    } finally {
        btn.disabled = false;
    }
}

async function loadLogPage(page) {
    const hideAdmin = document.getElementById('hideAdminCheck').checked;
    const res = await fetch(`/admin/search-logs?logPage=${page}&hideAdmin=${hideAdmin}`);
    const html = await res.text();
    document.getElementById('logTableArea').innerHTML = html;
}

async function updateSchedule(btn) {
    const hour   = parseInt(document.getElementById('schedHour').value, 10);
    const minute = parseInt(document.getElementById('schedMinute').value, 10);
    const resultEl = document.getElementById('result-update-schedule');
    resultEl.className = 'result-box';
    resultEl.style.display = 'block';
    resultEl.innerHTML = '<span class="spinner"></span>変更中…';
    btn.disabled = true;
    try {
        const body = new URLSearchParams({ hour, minute });
        const res  = await fetch('/admin/update-schedule', { method: 'POST', body });
        const data = await res.json();
        resultEl.className = 'result-box ' + (data.success ? 'ok' : 'err');
        resultEl.textContent = data.message;
    } catch (e) {
        resultEl.className = 'result-box err';
        resultEl.textContent = '通信エラー: ' + e.message;
    } finally {
        btn.disabled = false;
    }
}

async function runAction(action, btn) {
    const resultEl = document.getElementById('result-' + action);
    resultEl.className = 'result-box';
    resultEl.style.display = 'block';
    resultEl.innerHTML = '<span class="spinner"></span>実行中…';
    btn.disabled = true;
    try {
        const res  = await fetch('/admin/' + action, { method: 'POST' });
        const data = await res.json();
        resultEl.className = 'result-box ' + (data.success ? 'ok' : 'err');
        resultEl.textContent = data.message;
    } catch (e) {
        resultEl.className = 'result-box err';
        resultEl.textContent = '通信エラー: ' + e.message;
    } finally {
        btn.disabled = false;
    }
}
</script>
</body>
</html>
