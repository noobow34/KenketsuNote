@using KenketsuNote.Auth
@{
    Layout = null;
    var userId   = ViewBag.UserId as string ?? "";
    var userName = ViewBag.UserName as string;
    bool isAdmin = AdminAuth.IsAdmin(Context);
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="けんけつノート - 献血の記録をもっと楽しく。全国スタンプ帳と計画管理で、次の献血へ。">
    <meta property="og:type" content="website">
    <meta property="og:title" content="けんけつノート">
    <meta property="og:description" content="献血の記録をもっと楽しく。全国スタンプ帳と計画管理で、次の献血へ。">
    <meta property="og:image" content="https://kenketsu.noobow.me/image/logo1-ogp.png">
    <meta property="og:url" content="https://kenketsu.noobow.me/">
    <meta property="og:site_name" content="けんけつノート">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="けんけつノート">
    <meta name="twitter:description" content="献血の記録をもっと楽しく。全国スタンプ帳と計画管理で、次の献血へ。">
    <meta name="twitter:image" content="https://kenketsu.noobow.me/image/logo1-ogp.png">
    <meta name="twitter:creator" content="@@noobow">
    <link rel="manifest" href="/pwa/manifest?userId=@userId&page=hub">
    <meta name="theme-color" content="#d32f2f">
    <title>けんけつノート</title>
    <style>
        body {
            margin: 0;
            font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", Meiryo, sans-serif;
            background: #fafafa;
            color: #333;
        }
        .hub-wrap {
            max-width: 520px;
            margin: 60px auto;
            padding: 0 16px;
            text-align: center;
        }
        .hub-title img {
            height: 200px;
            width: auto;
            margin-bottom: 4px;
        }
        .hub-username {
            color: #555;
            margin: 0 0 32px;
        }
        .hub-menu {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .hub-card {
            display: flex;
            align-items: center;
            gap: 20px;
            background: #fff;
            border-radius: 16px;
            padding: 24px 28px;
            text-decoration: none;
            color: #333;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: box-shadow 0.2s, transform 0.15s;
            border-left: 6px solid #d32f2f;
        }
        .hub-card:hover {
            box-shadow: 0 6px 20px rgba(211,47,47,0.15);
            transform: translateY(-2px);
        }
        .hub-card-icon {
            font-size: 2.2em;
            flex-shrink: 0;
        }
        .hub-card-text {
            text-align: left;
        }
        .hub-card-name {
            font-size: 1.15em;
            font-weight: bold;
            color: #b71c1c;
            margin-bottom: 4px;
        }
        .hub-card-desc {
            font-size: 0.88em;
            color: #666;
        }
        .hub-notice {
            margin-top: 28px;
            background: #fff8e1;
            border: 1.5px solid #ffe082;
            border-radius: 12px;
            padding: 14px 18px;
            font-size: 0.82em;
            color: #5d4037;
            line-height: 1.7;
        }
        .hub-notice strong {
            display: block;
            font-size: 0.95em;
            margin-bottom: 4px;
            color: #b71c1c;
        }
        .hub-url {
            display: inline-block;
            font-family: monospace;
            font-size: 0.95em;
            background: #fff;
            border: 1px solid #f5c518;
            border-radius: 6px;
            padding: 4px 10px;
            margin: 6px 0;
            word-break: break-all;
            color: #333;
            cursor: pointer;
            user-select: all;
        }
        .hub-url:hover { background: #fffde7; }
        .hub-disclaimer {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid #ffe082;
            font-size: 0.9em;
            color: #8d6e63;
        }
        .hub-footer {
            margin-top: 32px;
            font-size: 0.8em;
            color: #aaa;
        }
        .hub-footer a {
            color: #ccc;
        }
    </style>
</head>
<body>
<div class="hub-wrap">
    <h1 class="hub-title"><img src="/image/logo1.png" alt="けんけつノート"></h1>
    @if (!string.IsNullOrEmpty(userName))
    {
        <p class="hub-username">@userName さん</p>
    }
    else
    {
        <p class="hub-username">マイページ</p>
    }
    <div class="hub-menu">
        <a href="/u/@userId/stamp" class="hub-card">
            <div class="hub-card-icon">🗾</div>
            <div class="hub-card-text">
                <div class="hub-card-name">全国スタンプ</div>
                <div class="hub-card-desc">全国の献血ルームをスタンプ帳で記録</div>
            </div>
        </a>
        <a href="/u/@userId/tracker" class="hub-card">
            <div class="hub-card-icon">📅</div>
            <div class="hub-card-text">
                <div class="hub-card-name">計画管理</div>
                <div class="hub-card-desc">献血の予定・実績・制限期間を管理</div>
            </div>
        </a>
        <a href="/manual" class="hub-card">
            <div class="hub-card-icon">📖</div>
            <div class="hub-card-text">
                <div class="hub-card-name">ヘルプ</div>
                <div class="hub-card-desc">使い方・ルール・よくある操作</div>
            </div>
        </a>
        <a href="/rooms" class="hub-card">
            <div class="hub-card-icon">🔍</div>
            <div class="hub-card-text">
                <div class="hub-card-name">献血ルーム検索</div>
                <div class="hub-card-desc">全国の献血ルームを条件で絞り込み</div>
            </div>
        </a>
        @if (isAdmin)
        {
            <a href="/admin" class="hub-card" style="border-left-color:#555;">
                <div class="hub-card-icon">⚙️</div>
                <div class="hub-card-text">
                    <div class="hub-card-name" style="color:#333;">管理画面</div>
                    <div class="hub-card-desc">ログ・差分チェック・マスタ管理</div>
                </div>
            </a>
        }
    </div>
    <div class="hub-notice">
        <strong>🔖 このページをブックマークしてご利用ください</strong>
        このURLがあなた専用のマイページです。次回以降はこのURLから直接アクセスしてください。
        <div>
            <span class="hub-url" title="クリックでURLをコピー" id="myUrl" onclick="copyMyUrl()"></span>
            <div id="urlCopyToast" style="font-size:0.8em;color:#388e3c;margin-top:2px;display:none;">コピーしました</div>
        </div>
        <div class="hub-disclaimer">
            ⚠ このURLを知っている人はだれでもページにアクセス・編集できます。URLの取り扱いにご注意ください。なお、記録の流出・消失について当方では責任を負いかねます。
        </div>
    </div>

    <button id="pwaInstallBtn" onclick="installPwa()" style="margin-top:20px;width:100%;padding:12px;background:#fff5f5;border:1.5px solid #d32f2f;border-radius:12px;color:#d32f2f;font-size:0.95rem;font-weight:600;cursor:pointer;">📲 ホーム画面に追加</button>

    <div class="hub-footer">
        <a href="/">けんけつノート トップ</a>
    </div>

    <script>
        document.getElementById('myUrl').textContent = window.location.href;
        function copyMyUrl() {
            navigator.clipboard.writeText(window.location.href).then(function() {
                var toast = document.getElementById('urlCopyToast');
                toast.style.display = 'block';
                setTimeout(function(){ toast.style.display = 'none'; }, 1500);
            });
        }
        var _pwaPrompt = null;
        window.addEventListener('beforeinstallprompt', function(e) {
            e.preventDefault(); _pwaPrompt = e;
        });
        window.addEventListener('appinstalled', function() {
            _pwaPrompt = null;
            document.getElementById('pwaInstallBtn').style.display = 'none';
        });
        function installPwa() {
            if (_pwaPrompt) {
                _pwaPrompt.prompt();
                _pwaPrompt.userChoice.then(function(){ _pwaPrompt = null; });
            } else {
                alert('Chromeのメニュー（⋮）→「ホーム画面に追加」をタップしてください。');
            }
        }
        if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
    </script>
</div>
@await Html.PartialAsync("_VersionFooter")
</body>
</html>
